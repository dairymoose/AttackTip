<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.blizzard.com/wow/ui/">
	<Script file="AttackTip.lua"/>
	<Frame name="AttackTip_Frame" parent="UIParent" hidden="false">
		<Scripts>
			<OnLoad>
				AttackTip_OnLoad()
			</OnLoad>
			<OnEvent>
				AttackTip_OnEvent()
			</OnEvent>
			<OnDragStart>
				self:StartMoving()
			</OnDragStart>
			<OnDragStop>
				self:StopMovingOrSizing()
			</OnDragStop>
		</Scripts>

		<Size>
			<AbsDimension x="200" y="10" />
		</Size>

	</Frame>
</Ui>
